{
  "_comment": "VORLAGE für neues Event – alle GROSSBUCHSTABEN-Werte ersetzen",

  "event": {
    "name":             "EVENT_NAME",
    "short_name":       "EVENT_KURZNAME",
    "date":             "JJJJ-MM-TT",
    "date_label":       "TT. Monat JJJJ",
    "location":         "ORT",
    "organizer":        "KBW e.V.",
    "reference_prefix": "XX-JJJJ",
    "reference_padding": 3
  },

  "bunny": {
    "_comment":      "Eigene Pull Zone pro Event anlegen unter bunny.net → CDN",
    "storage_zone":  "kbw-EVENTNAME",
    "storage_region":"de",
    "pull_zone_id":  "NUMERISCHE_PULL_ZONE_ID",
    "cdn_url":       "https://EVENTNAME.kbw.de",
    "deploy_prefix": ""
  },

  "smtp": {
    "from_name":      "EVENT_NAME",
    "reply_to":       "service@EVENTNAME.de",
    "subject_prefix": "EVENT_NAME"
  },

  "phases": {
    "pre_event": {
      "label":       "Vorab-Auswahl",
      "description": "Beschreibung der Vorab-Phase.",
      "opens_at":    "JJJJ-MM-TT",
      "closes_at":   "JJJJ-MM-TT",
      "active":      true
    },
    "event_day": {
      "label":       "Check-in",
      "description": "Beschreibung der Check-in-Phase.",
      "opens_at":    "JJJJ-MM-TTHH:MM:SS",
      "closes_at":   "JJJJ-MM-TTHH:MM:SS",
      "active":      true
    }
  },

  "participant": {
    "id_field":       "referenceNumber",
    "id_label":       "Bezugsnummer",
    "id_placeholder": "z. B. XX-JJJJ-001",
    "id_format":      "^XX-\\d{4}-\\d{3,4}$",
    "id_format_hint": "Format: XX-JJJJ-NNN",
    "fields": [
      { "key": "name",            "label": "Name",        "type": "text",  "required": true },
      { "key": "email",           "label": "E-Mail",       "type": "email", "required": true },
      { "key": "organization",    "label": "Organisation", "type": "text",  "required": true },
      { "key": "referenceNumber", "label": "Bezugsnummer", "type": "text",  "required": true, "readonly": true }
    ]
  },

  "selections": {
    "fachforum": {
      "label":       "SESSION_TYP_LABEL",
      "description": "Beschreibung der Auswahl.",
      "type":        "single",
      "required":    true,
      "min": 1, "max": 1,
      "db_table":    "fachforen",
      "options": [
        { "id": "forum-1", "title": "Option 1", "subtitle": "Beschreibung", "room": "Raum A", "capacity": 100 }
      ]
    },
    "programmpunkte": {
      "label":       "Rahmenprogramm",
      "description": "Bis zu N Punkte auswählbar.",
      "type":        "multi",
      "required":    false,
      "min": 0, "max": 5,
      "db_table":    "programmpunkte",
      "options": [
        { "id": "prog-1", "title": "Programmpunkt 1", "time": "HH:MM", "capacity": null }
      ]
    },
    "verpflegung": {
      "label":       "Verpflegung",
      "description": "Auswahl für alle Mahlzeiten.",
      "type":        "single",
      "required":    true,
      "min": 1, "max": 1,
      "db_table":    "food_options",
      "options": [
        { "id": "meal-1", "title": "Fleisch",     "value": "fleisch"     },
        { "id": "meal-2", "title": "Vegetarisch", "value": "vegetarisch" },
        { "id": "meal-3", "title": "Vegan",       "value": "vegan"       }
      ]
    },
    "lunchpacket": {
      "label":     "Lunchpaket",
      "description": "Lunchpaket statt Buffet.",
      "type":      "boolean",
      "required":  false,
      "db_column": "lunch_package",
      "default":   false
    }
  },

  "checkin": {
    "method":            "referenceNumber",
    "allow_manual":      true,
    "allow_qr":          true,
    "duplicate_message": "Diese Bezugsnummer wurde bereits eingecheckt.",
    "success_message":   "Herzlich willkommen! Ihre Anwesenheit wurde bestätigt."
  },

  "exports": {
    "catering":    { "columns": ["referenceNumber","name","organization","verpflegung","lunch_package"], "label": "Catering-Liste"        },
    "fachforum":   { "columns": ["referenceNumber","name","organization","fachforum_title","fachforum_room"], "label": "Fachforum-Zuteilung" },
    "anwesenheit": { "columns": ["referenceNumber","name","organization","status","checked_in_at"],       "label": "Anwesenheitsliste"      }
  }
}
